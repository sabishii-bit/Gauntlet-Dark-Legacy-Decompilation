# Formatting rules for decompiled sources.
#
# Kept deliberately minimal and aligned with GC/Wii decomp community style
# (zeldaret/tww, doldecomp/melee): attached braces, 4-space indent, wide
# lines. Imported reference sources then need little or no reformatting.
#
# Inline-asm functions (MWCC `asm`/`nofralloc` syntax) are not valid C to
# clang-format — every asm body must stay wrapped in
# `// clang-format off` ... `// clang-format on`.
---
Language: Cpp
Standard: c++03
BasedOnStyle: LLVM

IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 120

BreakBeforeBraces: Attach
PointerAlignment: Left
AllowShortFunctionsOnASingleLine: InlineOnly
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
IndentCaseLabels: false

# Decomp sources are matched against original binaries; don't let the
# formatter rearrange things that carry meaning for matching or research.
ReflowComments: false
SortIncludes: false
BreakStringLiterals: false
KeepEmptyLinesAtTheStartOfBlocks: false
MaxEmptyLinesToKeep: 1
CommentPragmas: '^ (IWYU pragma:|clang-format)'
...
